# Copy to .env and fill in.

APP_ENV=dev
LOG_LEVEL=INFO

# This address is used from Docker containers. For host-side DB tools use
# postgresql+psycopg://kle:kle@localhost:5433/kle instead.
DATABASE_URL=postgresql+psycopg://kle:kle@postgres:5432/kle
REDIS_URL=redis://redis:6379/0
# Keep per-process pools below the PostgreSQL connection budget. The default
# Compose topology has one API process and two Celery child processes.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

JWT_SECRET=change-me-please
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=60

CORS_ALLOW_ORIGINS=http://localhost:3000

# LLM (Ollama on the host machine, reached from Docker via host.docker.internal)
# Install Ollama on Windows/Mac, then run: ollama pull qwen2.5:3b-instruct
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=qwen2.5:3b-instruct
LLM_PRO_MODEL=qwen2.5:3b-instruct
LLM_API_KEY=

# Embeddings (local sentence-transformers, MiniLM-L6-v2, 384 dimensions)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=256
# Each full batch queues the next immediately, so this bounds memory and job
# duration rather than adding a two-minute gap between batches.
EMBEDDING_PENDING_LIMIT=2000
EMBEDDING_TASK_LOCK_SECONDS=3600
CLUSTER_TASK_LOCK_SECONDS=3600
# Docker Compose worker tuning for CPU-only embedding. Start here, then
# benchmark on the target hardware before increasing either value.
CELERY_WORKER_CONCURRENCY=2
EMBEDDING_CPU_THREADS=2

# Legacy Gemini vars (kept only so older .env files continue to load; unused
# by the current OpenAI-compatible client).
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# Answer-drafting knobs
ANSWER_TOP_K=6
ANSWER_CONFIDENCE_THRESHOLD=0.55
ANSWER_NO_AUTH=true

# Legacy model aliases (kept so older .env files do not break).
ANTHROPIC_API_KEY=
LLM_CLASSIFY_MODEL=gemini-2.5-flash
LLM_MERGE_MODEL=gemini-2.5-flash

# Retained compatibility settings. Current worker scoring and Beat schedules
# do not read these values; the compliance poll is currently every 15 minutes.
OUTDATED_AGE_DAYS=90
COMPLIANCE_POLL_MINUTES=60

# Optional notification and review-link settings.
PUBLIC_APP_URL=http://localhost:3000
SLACK_WEBHOOK_URL=
